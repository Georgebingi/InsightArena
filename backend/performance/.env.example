# Performance Testing Environment Variables

# API Base URL
API_BASE_URL=http://localhost:3000

# Oracle API Key (for oracle endpoint tests)
ORACLE_API_KEY=your-oracle-api-key-here

# Webhook Secret (for webhook signature verification)
WEBHOOK_SECRET=your-webhook-secret-here

# WebSocket URL (for WebSocket tests)
WS_URL=ws://localhost:3000

# Authentication Token (for authenticated endpoint tests)
AUTH_TOKEN=your-auth-token-here

# Test User Credentials
TEST_USER_EMAIL=perf-test@example.com
TEST_USER_PASSWORD=TestPassword123!
